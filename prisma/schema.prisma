// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SELLER
  USER
}

enum OrderStatus {
  DIPROSES
  SIAP_DIAMBIL
  SELESAI
}

enum PickupTime {
  ISTIRAHAT_1
  ISTIRAHAT_2
}

model Canteen {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  isActive    Boolean @default(true)

  users User[]
  menus Menu[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("canteens")
}

model User {
  id         Int      @id @default(autoincrement())
  clerkId    String?  @unique
  name       String
  email      String   @unique
  password   String?
  role       Role     @default(USER)
  balance    Float    @default(0)
  canteenId  Int?
  canteen    Canteen? @relation(fields: [canteenId], references: [id])
  orders     Order[]
  reviews    Review[]
  transactions Transaction[]
  favorites  Favorite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum MenuCategory {
  MAKANAN
  MINUMAN
  SNACK
}

model Menu {
  id          Int           @id @default(autoincrement())
  name        String
  price       Float
  image       String?       @db.LongText
  description String?
  category    MenuCategory  @default(MAKANAN)
  available   Boolean       @default(true)
  canteenId   Int?
  canteen     Canteen?      @relation(fields: [canteenId], references: [id])

  orderItems OrderItem[]
  reviews    Review[]
  favorites  Favorite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("menus")
}

model Order {
  id         Int         @id @default(autoincrement())
  userId     Int
  user       User        @relation(fields: [userId], references: [id])
  pickupTime PickupTime
  totalPrice Float
  status     OrderStatus @default(DIPROSES)
  items      OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("orders")
}

model OrderItem {
  id        Int   @id @default(autoincrement())
  orderId   Int
  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuId    Int
  menu      Menu  @relation(fields: [menuId], references: [id])
  quantity  Int
  unitPrice Float

  @@map("order_items")
}

enum TransactionType {
  TOPUP
  PAYMENT
}

enum TransactionStatus {
  PENDING
  APPROVED
  REJECTED
}

model Transaction {
  id        Int               @id @default(autoincrement())
  userId    Int
  user      User              @relation(fields: [userId], references: [id])
  type      TransactionType
  amount    Float
  note      String?
  orderId   Int?
  status    TransactionStatus @default(APPROVED)

  createdAt DateTime @default(now())

  @@map("transactions")
}

model Review {
  id       Int    @id @default(autoincrement())
  userId   Int
  user     User   @relation(fields: [userId], references: [id])
  menuId   Int
  menu     Menu   @relation(fields: [menuId], references: [id])
  orderId  Int
  rating   Int
  comment  String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, menuId, orderId])
  @@map("reviews")
}

model Favorite {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id])
  menuId Int
  menu   Menu @relation(fields: [menuId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, menuId])
  @@map("favorites")
}
